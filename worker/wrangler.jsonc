{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "quotidien-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-01",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "quotidien",
      "database_id": "REMPLACER_PAR_L_ID_D1",
      "migrations_dir": "migrations"
    }
  ],
  "triggers": {
    "crons": ["* * * * *"]
  },
  "vars": {
    "APP_ORIGIN": "https://pivot-consulting.github.io"
  }
}
